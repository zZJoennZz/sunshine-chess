---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Sunshine Chess | Fun Chess Classes for Kids in Florida! 🌞">
	<!-- HERO SECTION -->
	<section class="relative bg-gradient-to-br from-yellow-100 via-orange-50 to-coral-50 py-16 lg:py-24 overflow-hidden">
		<!-- Fun Background Blobs -->
		<div class="absolute top-20 left-10 w-32 h-32 bg-yellow-300 rounded-full opacity-40 blur-2xl animate-pulse"></div>
		<div class="absolute bottom-20 right-10 w-40 h-40 bg-coral-300 rounded-full opacity-30 blur-3xl animate-pulse" style="animation-delay: 1s;">
		</div>
		<div class="absolute top-1/2 left-1/4 w-24 h-24 bg-purple-300 rounded-full opacity-20 blur-xl animate-pulse" style="animation-delay: 2s;">
		</div>

		<div class="max-w-6xl mx-auto px-4 sm:px-6 relative z-10">
			<div class="grid lg:grid-cols-2 gap-12 items-center">
				<!-- Left Content -->
				<div class="text-center lg:text-left">
					<!-- Fun Badge -->
					<div
						class="inline-flex items-center gap-2 bg-white px-5 py-3 rounded-full shadow-lg border-3 border-yellow-400 mb-6 transform hover:scale-105 transition-transform"
					>
						<span class="text-xl">⭐</span>
						<span class="font-bold text-slate-800 text-sm lg:text-base">Step Up For Students Approved!</span>
					</div>

					<h1
						class="text-4xl md:text-5xl lg:text-6xl font-bold text-slate-800 leading-tight mb-6"
						style="font-family: 'Fredoka', sans-serif;"
					>
						Learn Chess with
						<span class="relative inline-block">
							<span class="text-orange-500">Sunshine</span>
							<span class="absolute -bottom-2 left-0 w-full h-4 bg-yellow-300 rounded-full -z-10 opacity-60"></span>
						</span>
						and
						<span class="text-coral-500">Smiles!</span>
						😎
					</h1>

					<p class="text-lg lg:text-xl text-slate-600 mb-8 max-w-lg mx-auto lg:mx-0 leading-relaxed">
						Join <strong class="text-orange-500">Coach Chris</strong> for super fun chess lessons across Florida! Make friends, win trophies,
						and become a chess champion! 🏆
					</p>

					<div class="flex flex-wrap gap-4 justify-center lg:justify-start">
						<a href="/register" class="btn-fun text-white px-8 py-4 text-lg font-bold inline-flex items-center gap-2">
							Start Your Adventure! 🚀
						</a>
						<a
							href="/about"
							class="bg-white text-slate-700 px-8 py-4 rounded-full text-lg font-bold border-4 border-yellow-300 hover:bg-yellow-50 hover:border-yellow-400 transition-all inline-flex items-center gap-2 shadow-lg"
						>
							Meet Coach Chris 👋
						</a>
					</div>

					<!-- Fun Stats -->
					<div class="flex flex-wrap gap-6 justify-center lg:justify-start mt-8">
						<div class="flex items-center gap-2 bg-white px-4 py-2 rounded-full shadow-md">
							<span class="text-2xl">🎓</span>
							<span class="font-bold text-slate-700">15+ Years</span>
						</div>
						<div class="flex items-center gap-2 bg-white px-4 py-2 rounded-full shadow-md">
							<span class="text-2xl">👦👧</span>
							<span class="font-bold text-slate-700">500+ Kids</span>
						</div>
						<div class="flex items-center gap-2 bg-white px-4 py-2 rounded-full shadow-md">
							<span class="text-2xl">⭐</span>
							<span class="font-bold text-slate-700">5 Star Fun!</span>
						</div>
					</div>
				</div>

				<!-- Right - Fun Sun Character -->
				<div class="relative flex justify-center items-center h-[400px] lg:h-[500px]">
					<!-- Main Sun - LOWER z-index -->
					<div class="sun-fun relative w-64 h-64 lg:w-80 lg:h-80 z-0">
						<!-- Sun Body -->
						<img
							src="/img/sunshine.png"
							alt="Sunshine Chess Logo"
							class="w-full h-full object-contain relative z-0 pointer-events-none"
						/>

						<!-- Rays - also lower -->
						<div class="absolute inset-0 animate-spin z-0" style="animation: spin 20s linear infinite;">
							<div class="absolute -top-4 left-1/2 -translate-x-1/2 w-8 h-8 bg-yellow-400 rounded-full shadow-lg z-0">✨</div>
							<div class="absolute -bottom-4 left-1/2 -translate-x-1/2 w-8 h-8 bg-orange-400 rounded-full shadow-lg z-0">⭐</div>
							<div class="absolute left-0 top-1/2 -translate-y-1/2 w-6 h-6 bg-coral-400 rounded-full shadow-lg z-0">💫</div>
							<div class="absolute right-0 top-1/2 -translate-y-1/2 w-6 h-6 bg-purple-400 rounded-full shadow-lg z-0">🌟</div>
						</div>
					</div>

					<!-- Orbiting Chess Pieces - HIGHER z-index -->
					<div class="absolute w-full h-full z-10 pointer-events-none" style="animation: orbit-fun 15s linear infinite;">
						<div
							class="chess-piece group absolute top-0 left-1/2 -translate-x-1/2 w-14 h-14 bg-white rounded-2xl shadow-lg flex items-center justify-center text-2xl border-3 border-yellow-300 transform hover:scale-110 transition-transform cursor-help pointer-events-auto"
						>
							♟️
							<div
								class="piece-tooltip absolute bottom-full left-1/2 -translate-x-1/2 mb-3 w-48 bg-slate-800 text-white text-sm rounded-2xl p-4 opacity-0 invisible transition-all duration-300 pointer-events-none shadow-xl z-50"
							>
								<div class="font-bold text-yellow-400 mb-1 text-base">♟️ Pawn</div>
								<p class="text-xs leading-relaxed">
									Moves forward 1 square (or 2 on first move). Captures diagonally. Promotes to any piece at the other end!
								</p>
								<div class="absolute top-full left-1/2 -translate-x-1/2 border-8 border-transparent border-t-slate-800"></div>
							</div>
						</div>
					</div>

					<div
						class="absolute w-full h-full z-10 pointer-events-none"
						style="animation: orbit-fun 15s linear infinite reverse; animation-delay: -3.75s;"
					>
						<div
							class="chess-piece group absolute bottom-0 left-1/2 -translate-x-1/2 w-14 h-14 bg-white rounded-2xl shadow-lg flex items-center justify-center text-2xl border-3 border-coral-300 transform hover:scale-110 transition-transform cursor-help pointer-events-auto"
						>
							♞
							<div
								class="piece-tooltip absolute bottom-full left-1/2 -translate-x-1/2 mb-3 w-48 bg-slate-800 text-white text-sm rounded-2xl p-4 opacity-0 invisible transition-all duration-300 pointer-events-none shadow-xl z-50"
							>
								<div class="font-bold text-coral-400 mb-1 text-base">♞ Knight</div>
								<p class="text-xs leading-relaxed">
									Moves in an "L" shape: 2 squares one way, then 1 square perpendicular. Can jump over other pieces!
								</p>
								<div class="absolute top-full left-1/2 -translate-x-1/2 border-8 border-transparent border-t-slate-800"></div>
							</div>
						</div>
					</div>

					<div
						class="absolute w-full h-full z-10 pointer-events-none"
						style="animation: orbit-fun 15s linear infinite; animation-delay: -7.5s;"
					>
						<div
							class="chess-piece group absolute left-0 top-1/2 -translate-y-1/2 w-14 h-14 bg-white rounded-2xl shadow-lg flex items-center justify-center text-2xl border-3 border-purple-300 transform hover:scale-110 transition-transform cursor-help pointer-events-auto"
						>
							♝
							<div
								class="piece-tooltip absolute left-full top-1/2 -translate-y-1/2 ml-3 w-48 bg-slate-800 text-white text-sm rounded-2xl p-4 opacity-0 invisible transition-all duration-300 pointer-events-none shadow-xl z-50"
							>
								<div class="font-bold text-purple-400 mb-1 text-base">♝ Bishop</div>
								<p class="text-xs leading-relaxed">
									Moves diagonally any number of squares. Stays on the same color square for the whole game!
								</p>
								<div class="absolute top-1/2 right-full -translate-y-1/2 border-8 border-transparent border-r-slate-800"></div>
							</div>
						</div>
					</div>

					<div
						class="absolute w-full h-full z-10 pointer-events-none"
						style="animation: orbit-fun 15s linear infinite reverse; animation-delay: -11.25s;"
					>
						<div
							class="chess-piece group absolute right-0 top-1/2 -translate-y-1/2 w-14 h-14 bg-white rounded-2xl shadow-lg flex items-center justify-center text-2xl border-3 border-sky-300 transform hover:scale-110 transition-transform cursor-help pointer-events-auto"
						>
							♜
							<div
								class="piece-tooltip absolute right-full top-1/2 -translate-y-1/2 mr-3 w-48 bg-slate-800 text-white text-sm rounded-2xl p-4 opacity-0 invisible transition-all duration-300 pointer-events-none shadow-xl z-50"
							>
								<div class="font-bold text-sky-400 mb-1 text-base">♜ Rook</div>
								<p class="text-xs leading-relaxed">
									Moves horizontally or vertically any number of squares. Teams up with the King to castle!
								</p>
								<div class="absolute top-1/2 left-full -translate-y-1/2 border-8 border-transparent border-l-slate-800"></div>
							</div>
						</div>
					</div>

					<!-- Floating Decorations - also high z-index -->
					<div class="absolute top-10 right-10 text-4xl animate-bounce z-10" style="animation-duration: 2s;">🎈</div>
					<div class="absolute bottom-20 left-5 text-3xl animate-bounce z-10" style="animation-duration: 2.5s; animation-delay: 0.5s;">
						🌟
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- FUN FEATURES BAR -->
	<section class="relative z-20 -mt-8 px-4">
		<div class="max-w-5xl mx-auto bg-white rounded-[2rem] shadow-xl p-6 lg:p-8 border-4 border-yellow-200">
			<div class="grid md:grid-cols-3 gap-6 text-center">
				<div class="card-fun p-6 bg-gradient-to-br from-yellow-50 to-orange-50">
					<div class="w-16 h-16 bg-yellow-400 rounded-full flex items-center justify-center text-3xl mx-auto mb-3 shadow-lg">🎓</div>
					<h3 class="font-bold text-lg text-slate-800 mb-1">Step Up Approved!</h3>
					<p class="text-slate-600 text-sm">Scholarships make chess FREE for your family!</p>
				</div>

				<div class="card-fun p-6 bg-gradient-to-br from-coral-50 to-pink-50">
					<div class="w-16 h-16 bg-coral-400 rounded-full flex items-center justify-center text-3xl mx-auto mb-3 shadow-lg">🏆</div>
					<h3 class="font-bold text-lg text-slate-800 mb-1">Win Trophies!</h3>
					<p class="text-slate-600 text-sm">Join tournaments and bring home the gold!</p>
				</div>

				<div class="card-fun p-6 bg-gradient-to-br from-sky-50 to-teal-50">
					<div class="w-16 h-16 bg-sky-400 rounded-full flex items-center justify-center text-3xl mx-auto mb-3 shadow-lg">🌴</div>
					<h3 class="font-bold text-lg text-slate-800 mb-1">All Over Florida!</h3>
					<p class="text-slate-600 text-sm">Classes near you from Miami to Tallahassee!</p>
				</div>
			</div>
		</div>
	</section>

	<!-- LESSONS SECTION -->
	<section class="py-16 lg:py-24 bg-white">
		<div class="max-w-6xl mx-auto px-4 sm:px-6">
			<div class="text-center mb-12">
				<span class="inline-block bg-yellow-300 text-slate-800 px-6 py-2 rounded-full font-bold text-sm mb-4">🎯 Pick Your Level</span>
				<h2 class="text-3xl lg:text-5xl font-bold text-slate-800 mb-4" style="font-family: 'Fredoka', sans-serif;">
					Chess Lessons Made <span class="text-orange-500">Fun!</span> 🎮
				</h2>
				<p class="text-lg text-slate-600 max-w-2xl mx-auto">
					From your very first move to tournament champion — we've got the perfect class for YOU!
				</p>
			</div>

			<div class="grid md:grid-cols-3 gap-8">
				<!-- Beginners -->
				<div class="card-fun overflow-hidden bg-gradient-to-b from-white to-yellow-50">
					<div class="h-48 bg-gradient-to-br from-yellow-300 to-orange-400 relative overflow-hidden">
						<!-- Placeholder Image -->
						<div class="absolute inset-0 flex items-center justify-center">
							<div class="text-center">
								<span class="text-6xl">🌟</span>
								<p class="text-white font-bold mt-2">[Kids Learning Chess]</p>
							</div>
						</div>
						<div class="absolute top-4 right-4 bg-white px-3 py-1 rounded-full text-sm font-bold text-slate-800">Ages 5-12</div>
					</div>
					<div class="p-6">
						<h3 class="text-2xl font-bold text-slate-800 mb-2" style="font-family: 'Fredoka', sans-serif;">Beginners 🌱</h3>
						<p class="text-slate-600 mb-4">Learn how pieces move, play your first game, and make new friends!</p>

						<ul class="space-y-2 mb-6">
							<li class="flex items-center gap-2 text-slate-700">
								<span class="w-6 h-6 bg-green-400 rounded-full flex items-center justify-center text-white text-xs">✓</span>
								Fun piece characters & stories
							</li>
							<li class="flex items-center gap-2 text-slate-700">
								<span class="w-6 h-6 bg-green-400 rounded-full flex items-center justify-center text-white text-xs">✓</span>
								Chess puzzles & mini-games
							</li>
							<li class="flex items-center gap-2 text-slate-700">
								<span class="w-6 h-6 bg-green-400 rounded-full flex items-center justify-center text-white text-xs">✓</span>
								First tournament ready!
							</li>
						</ul>

						<div class="flex items-center justify-between pt-4 border-t-2 border-dashed border-yellow-300">
							<div>
								<span class="text-3xl font-bold text-slate-800">$45</span>
								<span class="text-slate-500 text-sm">/class</span>
							</div>
							<a
								href="/lessons"
								class="bg-yellow-400 hover:bg-yellow-500 text-slate-800 px-6 py-3 rounded-full font-bold transition-colors"
							>
								Join! 🚀
							</a>
						</div>
					</div>
				</div>

				<!-- Intermediate -->
				<div class="card-fun overflow-hidden bg-gradient-to-b from-white to-coral-50">
					<div class="h-48 bg-gradient-to-br from-coral-400 to-pink-500 relative overflow-hidden">
						<!-- Placeholder Image -->
						<div class="absolute inset-0 flex items-center justify-center">
							<div class="text-center">
								<span class="text-6xl">⚡</span>
								<p class="text-white font-bold mt-2">[Kids Playing Tournament]</p>
							</div>
						</div>
						<div class="absolute top-4 right-4 bg-white px-3 py-1 rounded-full text-sm font-bold text-slate-800">Ages 8-14</div>
					</div>
					<div class="p-6">
						<h3 class="text-2xl font-bold text-slate-800 mb-2" style="font-family: 'Fredoka', sans-serif;">Intermediate ⚡</h3>
						<p class="text-slate-600 mb-4">Master tactics, learn cool openings, and crush the competition!</p>

						<ul class="space-y-2 mb-6">
							<li class="flex items-center gap-2 text-slate-700">
								<span class="w-6 h-6 bg-coral-400 rounded-full flex items-center justify-center text-white text-xs">✓</span>
								Sneaky tactics & traps
							</li>
							<li class="flex items-center gap-2 text-slate-700">
								<span class="w-6 h-6 bg-coral-400 rounded-full flex items-center justify-center text-white text-xs">✓</span>
								Opening superpowers
							</li>
							<li class="flex items-center gap-2 text-slate-700">
								<span class="w-6 h-6 bg-coral-400 rounded-full flex items-center justify-center text-white text-xs">✓</span>
								Rated tournaments!
							</li>
						</ul>

						<div class="flex items-center justify-between pt-4 border-t-2 border-dashed border-coral-300">
							<div>
								<span class="text-3xl font-bold text-slate-800">$55</span>
								<span class="text-slate-500 text-sm">/class</span>
							</div>
							<a href="/lessons" class="bg-coral-400 hover:bg-coral-500 text-white px-6 py-3 rounded-full font-bold transition-colors">
								Level Up! 🎮
							</a>
						</div>
					</div>
				</div>

				<!-- Advanced -->
				<div class="card-fun overflow-hidden bg-gradient-to-b from-white to-purple-50">
					<div class="h-48 bg-gradient-to-br from-purple-500 to-indigo-600 relative overflow-hidden">
						<!-- Placeholder Image -->
						<div class="absolute inset-0 flex items-center justify-center">
							<div class="text-center">
								<span class="text-6xl">👑</span>
								<p class="text-white font-bold mt-2">[Champion with Trophy]</p>
							</div>
						</div>
						<div class="absolute top-4 right-4 bg-white px-3 py-1 rounded-full text-sm font-bold text-slate-800">Ages 10-16</div>
					</div>
					<div class="p-6">
						<h3 class="text-2xl font-bold text-slate-800 mb-2" style="font-family: 'Fredoka', sans-serif;">Advanced 👑</h3>
						<p class="text-slate-600 mb-4">Become a chess master! Deep strategy, endgame magic, and championship prep.</p>

						<ul class="space-y-2 mb-6">
							<li class="flex items-center gap-2 text-slate-700">
								<span class="w-6 h-6 bg-purple-500 rounded-full flex items-center justify-center text-white text-xs">✓</span>
								Grandmaster strategies
							</li>
							<li class="flex items-center gap-2 text-slate-700">
								<span class="w-6 h-6 bg-purple-500 rounded-full flex items-center justify-center text-white text-xs">✓</span>
								Endgame wizardry
							</li>
							<li class="flex items-center gap-2 text-slate-700">
								<span class="w-6 h-6 bg-purple-500 rounded-full flex items-center justify-center text-white text-xs">✓</span>
								State championship ready!
							</li>
						</ul>

						<div class="flex items-center justify-between pt-4 border-t-2 border-dashed border-purple-300">
							<div>
								<span class="text-3xl font-bold text-slate-800">$65</span>
								<span class="text-slate-500 text-sm">/class</span>
							</div>
							<a
								href="/lessons"
								class="bg-purple-500 hover:bg-purple-600 text-white px-6 py-3 rounded-full font-bold transition-colors"
							>
								Go Pro! 🏆
							</a>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- COACH CHRIS SECTION -->
	<section class="py-16 lg:py-24 bg-gradient-to-br from-sky-400 via-purple-500 to-pink-500 relative overflow-hidden">
		<!-- Fun Background Pattern -->
		<div
			class="absolute inset-0 opacity-10 text-9xl text-white overflow-hidden whitespace-nowrap select-none"
			style="font-size: 15rem; line-height: 1;"
		>
			♔♕♖♗♘♙♔♕♖♗♘♙
		</div>

		<div class="max-w-5xl mx-auto px-4 sm:px-6 relative z-10">
			<div class="bg-white rounded-[2.5rem] p-8 lg:p-12 shadow-2xl">
				<div class="grid lg:grid-cols-2 gap-12 items-center">
					<!-- Photo Placeholder -->
					<div class="relative">
						<div
							class="bg-gradient-to-br from-yellow-300 to-orange-400 rounded-[2rem] p-2 transform -rotate-3 hover:rotate-0 transition-transform duration-500"
						>
							<div class="bg-white rounded-[1.5rem] overflow-hidden aspect-square flex items-center justify-center">
								<div class="text-center">
									<span class="text-8xl">👨‍🏫</span>
									<p class="text-slate-400 font-bold mt-4">[Photo of Coach Chris]</p>
									<p class="text-slate-400 text-sm">Teaching with a smile!</p>
								</div>
							</div>
						</div>
						<!-- Floating Badge -->
						<div
							class="absolute -bottom-4 -right-4 bg-yellow-400 text-slate-800 px-6 py-3 rounded-full font-bold shadow-lg transform rotate-6"
						>
							15+ Years! 🎉
						</div>
					</div>

					<div>
						<span class="inline-block bg-sky-100 text-sky-700 px-4 py-2 rounded-full font-bold text-sm mb-4">👋 Meet Your Coach</span>
						<h2 class="text-4xl lg:text-5xl font-bold text-slate-800 mb-4" style="font-family: 'Fredoka', sans-serif;">
							Coach <span class="text-orange-500">Chris</span>! 🎓
						</h2>

						<p class="text-lg text-slate-600 mb-4 leading-relaxed">
							Hey there, future chess champion! I'm Coach Chris, and I've been teaching kids just like you to love chess for over <strong
								class="text-orange-500"
							>
								15 years
							</strong>!
						</p>

						<p class="text-lg text-slate-600 mb-6 leading-relaxed">
							I make chess <strong class="text-coral-500">super fun</strong> with games, stories, and challenges. Whether you're brand new
							or ready for tournaments, we'll learn together and have a blast! 🌟
						</p>

						<div class="grid grid-cols-3 gap-4 mb-8">
							<div class="bg-yellow-100 rounded-2xl p-4 text-center">
								<span class="block text-3xl font-bold text-yellow-600" style="font-family: 'Fredoka', sans-serif;">500+</span>
								<span class="text-sm text-slate-600">Happy Students</span>
							</div>
							<div class="bg-coral-100 rounded-2xl p-4 text-center">
								<span class="block text-3xl font-bold text-coral-600" style="font-family: 'Fredoka', sans-serif;">2200</span>
								<span class="text-sm text-slate-600">Chess Rating</span>
							</div>
							<div class="bg-purple-100 rounded-2xl p-4 text-center">
								<span class="block text-3xl font-bold text-purple-600" style="font-family: 'Fredoka', sans-serif;">⭐⭐⭐</span>
								<span class="text-sm text-slate-600">5 Star Fun!</span>
							</div>
						</div>

						<a
							href="/about"
							class="inline-flex items-center gap-2 bg-slate-800 text-white px-8 py-4 rounded-full font-bold hover:bg-slate-700 transition-colors"
						>
							Read My Story 📖
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- FLORIDA MAP SECTION -->
	<section class="py-16 lg:py-24 bg-yellow-50">
		<div class="max-w-6xl mx-auto px-4 sm:px-6">
			<div class="text-center mb-12">
				<span class="inline-block bg-orange-400 text-white px-6 py-2 rounded-full font-bold text-sm mb-4">🗺️ Find Your Class</span>
