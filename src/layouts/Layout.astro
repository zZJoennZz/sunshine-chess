---
import '../styles/global.css';

export interface Props {
	title: string;
	description?: string;
}

const {
	title = 'Sunshine Chess | Fun Chess for Kids in Florida',
	description = 'Playful chess classes for kids across Florida! Step Up For Students approved. Join Coach Chris for fun lessons and tournaments.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<meta name="description" content={description} />

		<!-- Fonts -->
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;500;600;700&family=Nunito:wght@400;600;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="bg-cream font-sans text-slate-800" style="font-family: 'Nunito', sans-serif;">
		<!-- SEO -->
		<div class="absolute -left-full w-px h-px overflow-hidden" aria-hidden="true">
			Fun chess classes Florida, Kids chess lessons, Step Up For Students chess, Sunshine Chess Academy, Coach Chris chess, Chess camp for kids
			Florida, Playful chess instruction, Youth chess club Florida
		</div>

		<!-- Navigation -->
		<nav class="fixed w-full top-0 z-50 bg-white shadow-md border-b-4 border-yellow-400">
			<div class="max-w-6xl mx-auto px-4 sm:px-6">
				<div class="flex justify-between items-center h-24">
					<!-- Logo -->
					<a href="/" class="flex items-center gap-3 group">
						<div class="flex flex-col leading-none">
							<img src="/img/logo.png" alt="Sunshine Chess Logo" class="w-[200px] md:w-[250px] p-2" />
						</div>
					</a>

					<!-- Desktop Menu -->
					<div class="hidden md:flex items-center gap-3">
						<a href="/" class="nav-pill text-slate-600 hover:bg-yellow-100 hover:text-slate-900">Home</a>
						<a href="/lessons" class="nav-pill text-slate-600 hover:bg-yellow-100 hover:text-slate-900">Lessons</a>
						<a href="/faq" class="nav-pill text-slate-600 hover:bg-yellow-100 hover:text-slate-900">FAQ</a>
						<a href="/contact" class="nav-pill text-slate-600 hover:bg-yellow-100 hover:text-slate-900">Contact</a>
						<a href="/about" class="nav-pill text-slate-600 hover:bg-yellow-100 hover:text-slate-900">About Me</a>
						<a href="/register" class="register-pill text-white hover:shadow-xl hover:scale-105 transition-all">Register 🚀</a>
					</div>

					<!-- Mobile Button -->
					<button
						id="mobileMenuBtn"
						class="md:hidden w-12 h-12 bg-gradient-to-br from-yellow-400 to-orange-400 rounded-2xl text-white text-xl shadow-lg flex items-center justify-center"
						aria-label="Open menu"
					>
						☰
					</button>
				</div>
			</div>
		</nav>

		<!-- Mobile Menu - MOVED OUTSIDE NAV -->
		<div id="mobileMenu" class="hidden fixed inset-0 z-[60] bg-white pt-24 pb-8 px-6 overflow-y-auto">
			<div class="flex flex-col gap-4 max-w-md mx-auto">
				<a href="/" class="nav-pill text-center text-lg text-slate-700 py-4">Home</a>
				<a href="/lessons" class="nav-pill text-center text-lg text-slate-700 py-4">Lessons</a>
				<a href="/faq" class="nav-pill text-center text-lg text-slate-700 py-4">FAQ</a>
				<a href="/contact" class="nav-pill text-center text-lg text-slate-700 py-4">Contact</a>
				<a href="/about" class="nav-pill text-center text-lg text-slate-700 py-4">About Me</a>
				<a href="/register" class="register-pill text-center text-lg text-white py-5 mt-4">Register Now 🚀</a>

				<!-- Close button -->
				<button id="closeMobileMenu" class="mt-4 w-full py-3 text-slate-500 font-semibold text-center">Close ✕</button>
			</div>
		</div>

		<!-- HERO - FUN & PLAYFUL -->
		<main class="pt-24">
			<slot />
		</main>

		<!-- FOOTER -->
		<footer class="bg-slate-800 text-white rounded-t-[3rem] mt-20">
			<div class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
				<div class="text-center mb-8">
					<div class="inline-flex items-center gap-3 bg-white/10 backdrop-blur-sm px-6 py-3 rounded-full">
						<span class="text-3xl">😎</span>
						<div>
							<h3 class="text-2xl font-bold text-yellow-400" style="font-family: 'Fredoka', sans-serif;">Sunshine Chess</h3>
							<p class="text-white/70 text-sm">Where Every Move Shines! ✨</p>
						</div>
					</div>
				</div>

				<div class="grid md:grid-cols-3 gap-8 text-center md:text-left">
					<div>
						<h4 class="text-yellow-400 font-bold mb-4 text-lg">🌟 Quick Links</h4>
						<ul class="space-y-2 text-white/80">
							<li><a href="/lessons" class="hover:text-yellow-400 transition-colors">📚 Lessons</a></li>
							<li><a href="/about" class="hover:text-yellow-400 transition-colors">👨‍🏫 About Me</a></li>
							<li><a href="/faq" class="hover:text-yellow-400 transition-colors">❓ FAQ</a></li>
							<li><a href="/register" class="hover:text-yellow-400 transition-colors">🚀 Register</a></li>
						</ul>
					</div>

					<div>
						<h4 class="text-yellow-400 font-bold mb-4 text-lg">🎓 Programs</h4>
						<ul class="space-y-2 text-white/80">
							<li><a href="/step-up" class="hover:text-yellow-400 transition-colors">Step Up Approved</a></li>
							<li><a href="/locations" class="hover:text-yellow-400 transition-colors">📍 Locations</a></li>
							<li><a href="/contact" class="hover:text-yellow-400 transition-colors">📧 Contact</a></li>
						</ul>
					</div>

					<div>
						<h4 class="text-yellow-400 font-bold mb-4 text-lg">📞 Get In Touch</h4>
						<ul class="space-y-2 text-white/80">
							<li>chris@sunshinechess.com</li>
							<li>(305) 555-CHESS</li>
						</ul>
					</div>
				</div>

				<div class="mt-8 pt-8 border-t border-white/20 text-center text-white/50 text-sm">
					<p>© 2026 <span class="text-yellow-400 font-bold">Sunshine Chess</span> 🌴 Step Up For Students Approved</p>
				</div>
			</div>
		</footer>

		<!-- EMAIL POPUP -->
		<div id="emailPopup" class="fixed inset-0 z-[70] hidden items-center justify-center p-4">
			<!-- Backdrop -->
			<div id="popupBackdrop" class="absolute inset-0 bg-slate-900/60 backdrop-blur-sm transition-opacity opacity-0"></div>

			<!-- Popup Card -->
			<div
				id="popupCard"
				class="relative bg-white rounded-[2rem] shadow-2xl max-w-md w-full p-8 transform scale-90 opacity-0 transition-all duration-300 border-4 border-yellow-300"
			>
				<!-- Close Button -->
				<button
					id="closePopup"
					class="absolute top-4 right-4 w-10 h-10 bg-slate-100 hover:bg-slate-200 rounded-full flex items-center justify-center text-slate-500 transition-colors"
					aria-label="Close popup"
				>
					✕
				</button>

				<!-- Content -->
				<div class="text-center">
					<div
						class="w-20 h-20 bg-gradient-to-br from-yellow-400 to-orange-400 rounded-full flex items-center justify-center text-4xl mx-auto mb-4 shadow-lg"
					>
						📬
					</div>

					<h3 class="text-2xl lg:text-3xl font-bold text-slate-800 mb-2" style="font-family: 'Fredoka', sans-serif;">Don't Miss a Move!</h3>

					<p class="text-slate-600 mb-6 leading-relaxed">
						Get Coach Chris's <strong class="text-orange-500">once-a-month email</strong> with everywhere he's teaching across Florida! 🌴
					</p>

					<form id="popupForm" class="space-y-4">
						<div>
							<input
								type="email"
								id="popupEmail"
								name="email"
								placeholder="your@email.com"
								required
								class="w-full px-5 py-4 rounded-2xl border-2 border-yellow-200 focus:border-yellow-400 focus:ring-4 focus:ring-yellow-100 outline-none transition-all text-slate-800 placeholder-slate-400 bg-yellow-50/50 text-center"
							/>
						</div>

						<button
							type="submit"
							class="w-full bg-gradient-to-r from-yellow-400 to-orange-400 hover:from-yellow-500 hover:to-orange-500 text-slate-900 font-bold py-4 rounded-2xl shadow-lg hover:shadow-xl transform hover:-translate-y-1 transition-all text-lg"
						>
							Subscribe! 🚀
						</button>
					</form>

					<p class="text-xs text-slate-400 mt-4">No spam, ever. Unsubscribe anytime. We only email once a month! ✨</p>

					<button id="noThanks" class="mt-4 text-sm text-slate-400 hover:text-slate-600 underline transition-colors">
						No thanks, maybe later
					</button>
				</div>
			</div>
		</div>

		<!-- POPUP STYLES -->
		<style>
			#emailPopup.active {
				display: flex;
			}
			#emailPopup.active #popupBackdrop {
				opacity: 1;
			}
			#emailPopup.active #popupCard {
				opacity: 1;
				transform: scale(1);
			}
		</style>

		<script>
			/* === MOBILE MENU === */
			const btn = document.getElementById('mobileMenuBtn');
			const menu = document.getElementById('mobileMenu');
			const closeBtn = document.getElementById('closeMobileMenu');

			function toggleMenu() {
				menu?.classList.toggle('hidden');
				document.body.classList.toggle('overflow-hidden');
			}

			btn?.addEventListener('click', toggleMenu);
			closeBtn?.addEventListener('click', toggleMenu);

			/* === EMAIL POPUP === */
			const POPUP_COOKIE_NAME = 'sunshinePopupClosed';
			const POPUP_COOKIE_DAYS = 30;
			const POPUP_DELAY_MS = 4000; // Show after 4 seconds

			const popup = document.getElementById('emailPopup');
			const popupBackdrop = document.getElementById('popupBackdrop');
			const popupClose = document.getElementById('closePopup');
			const popupNoThanks = document.getElementById('noThanks');
			const popupForm = document.getElementById('popupForm');

			// Cookie helpers
			function setCookie(name: string, value: string, days: number) {
				const expires = new Date(Date.now() + days * 864e5).toUTCString();
				document.cookie = name + '=' + encodeURIComponent(value) + '; expires=' + expires + '; path=/; SameSite=Lax';
			}

			function getCookie(name: string) {
				return document.cookie.split('; ').reduce((r, v) => {
					const parts = v.split('=');
					return parts[0] === name ? decodeURIComponent(parts[1]) : r;
				}, '');
			}

			function closePopup() {
				popup?.classList.remove('active');
				document.body.classList.remove('overflow-hidden');
				setCookie(POPUP_COOKIE_NAME, 'true', POPUP_COOKIE_DAYS);
			}

			function showPopup() {
				if (getCookie(POPUP_COOKIE_NAME)) return;
				popup?.classList.add('active');
				document.body.classList.add('overflow-hidden');
			}

			// Show after delay
			setTimeout(() => {
				showPopup();
			}, POPUP_DELAY_MS);

			// Close events
			popupClose?.addEventListener('click', closePopup);
			popupNoThanks?.addEventListener('click', closePopup);
			popupBackdrop?.addEventListener('click', closePopup);

			// Form submit
			popupForm?.addEventListener('submit', (e) => {
				e.preventDefault();
				const emailInput = document.getElementById('popupEmail') as HTMLInputElement | null;
				const email = emailInput?.value;

				// TODO: Connect to your email service (Mailchimp, ConvertKit, etc.)
				console.log('Newsletter signup:', email);

				// Show success state
				popupForm.innerHTML = `
					<div class="text-center py-4">
						<div class="text-5xl mb-3">🎉</div>
						<h4 class="text-xl font-bold text-slate-800 mb-2">You're In!</h4>
						<p class="text-slate-600">Watch your inbox for Coach Chris's next update!</p>
					</div>
				`;

				setTimeout(closePopup, 2500);
				setCookie(POPUP_COOKIE_NAME, 'true', POPUP_COOKIE_DAYS);
			});
		</script>
	</body>
</html>
